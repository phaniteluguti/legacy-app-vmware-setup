# =============================================================================
# VMware vSphere Connection  (fill in your values)
# =============================================================================
vsphere_server               = "vcenter.example.com"
vsphere_user                 = "administrator@vsphere.local"
vsphere_password             = "CHANGE_ME"
vsphere_allow_unverified_ssl = true

# =============================================================================
# vSphere Infrastructure
# =============================================================================
vsphere_datacenter = "Datacenter1"
vsphere_cluster    = "Cluster1"
vsphere_datastore  = "datastore1"
vsphere_network    = "VM Network"
vsphere_folder     = "legacy-apps"
vm_template_name   = "ubuntu-2204-template"

# =============================================================================
# VM Networking
# =============================================================================
vm_domain    = "lab.local"
vm_gateway   = "192.168.1.1"
vm_netmask   = 24
vm_dns_servers = ["8.8.8.8", "8.8.4.4"]
vm_ssh_user            = "ubuntu"
vm_ssh_private_key_path = "~/.ssh/id_rsa"

# =============================================================================
# Per-VM Settings
# =============================================================================
# Java VM — Spring PetClinic + PostgreSQL
java_vm_ip     = "192.168.1.101"
java_vm_cpus   = 2
java_vm_memory = 4096
java_vm_disk   = 40

# .NET VM — ASP.NET Core + SQL Server
dotnet_vm_ip     = "192.168.1.102"
dotnet_vm_cpus   = 2
dotnet_vm_memory = 4096
dotnet_vm_disk   = 40

# PHP VM — Laravel + MySQL
php_vm_ip     = "192.168.1.103"
php_vm_cpus   = 2
php_vm_memory = 2048
php_vm_disk   = 30
